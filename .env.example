# Runtime
HNG_DB_PATH=./data/hng.sqlite3
HNG_SCAN_INTERVAL_SECONDS=60
HNG_MODE=safe

# Network scanning
HNG_ARP_COMMAND=arp -an
HNG_ALLOWED_MACS=

# Malicious traffic controls
HNG_MALICIOUS_EVENTS_FILE=./data/malicious_events.jsonl
HNG_PORTSCAN_THRESHOLD=25
HNG_FAILED_AUTH_THRESHOLD=8
HNG_BLOCK_COMMAND=sudo pfctl -t hng_blocklist -T add {source}

# Credential/password-change checks
HNG_CREDENTIAL_SNAPSHOT_PATH=./data/credential_snapshot.json
HNG_DEVICE_CONFIG_PATH=./data/device_configs.json

# Notifications
HNG_NOTIFY_EMAIL_ENABLED=false
HNG_NOTIFY_EMAIL_TO=
HNG_SMTP_HOST=
HNG_SMTP_PORT=587
HNG_SMTP_USERNAME=
HNG_SMTP_PASSWORD=
HNG_NOTIFY_TELEGRAM_ENABLED=false
HNG_TELEGRAM_BOT_TOKEN=
HNG_TELEGRAM_CHAT_ID=
